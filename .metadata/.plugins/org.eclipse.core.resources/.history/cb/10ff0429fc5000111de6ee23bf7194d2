package com.meditrack.appointment.controller;

import com.meditrack.appointment.dto.AppointmentRequest;
import com.meditrack.appointment.dto.CancelRequest;
import com.meditrack.appointment.entity.Appointment;
import com.meditrack.appointment.entity.AppointmentStatus;
import com.meditrack.appointment.service.AppointmentService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

import java.time.LocalDate;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class AppointmentControllerTest {

    @Mock
    private AppointmentService appointmentService;

    @InjectMocks
    private AppointmentController controller;

    private Appointment appointment;
    private AppointmentRequest request;

    @BeforeEach
    void setUp() {
        appointment = new Appointment();
        appointment.setId(1L);
        appointment.setPatientId(10L);
        appointment.setPatientName("Aishu");
        appointment.setDoctorId(20L);
        appointment.setDoctorName("Dr. Mehta");
        appointment.setAppointmentDate(LocalDate.of(2026, 6, 15));
        appointment.setSlot("10:00 AM");
        appointment.setStatus(AppointmentStatus.PENDING_PAYMENT);

        request = new AppointmentRequest();
        request.setDoctorId(20L);
        request.setAppointmentDate(LocalDate.of(2026, 6, 15));
        request.setSlot("10:00 AM");
    }

    // ─────────────────────────────────────────────
    // POST /appointments/book
    // ─────────────────────────────────────────────

    @Test
    void bookAppointment_ShouldReturn201WithAppointment() {
        when(appointmentService.bookAppointment(request)).thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.bookAppointment(request);

        assertNotNull(response);
        assertEquals(HttpStatus.CREATED, response.getStatusCode());
        assertEquals(appointment, response.getBody());
        verify(appointmentService, times(1)).bookAppointment(request);
    }

    @Test
    void bookAppointment_ShouldDelegateToServiceWithSameRequest() {
        when(appointmentService.bookAppointment(request)).thenReturn(appointment);

        controller.bookAppointment(request);

        verify(appointmentService).bookAppointment(request);
    }

    // ─────────────────────────────────────────────
    // GET /appointments/{id}
    // ─────────────────────────────────────────────

    @Test
    void getById_ShouldReturn200WithAppointment() {
        when(appointmentService.getAppointmentById(1L)).thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.getById(1L);

        assertNotNull(response);
        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(1L, response.getBody().getId());
        verify(appointmentService, times(1)).getAppointmentById(1L);
    }

    @Test
    void getById_ShouldPassCorrectIdToService() {
        when(appointmentService.getAppointmentById(99L)).thenReturn(appointment);

        controller.getById(99L);

        verify(appointmentService).getAppointmentById(99L);
        verify(appointmentService, never()).getAppointmentById(1L);
    }

    // ─────────────────────────────────────────────
    // GET /appointments/all
    // ─────────────────────────────────────────────

    @Test
    void getAll_ShouldReturn200WithList() {
        Appointment appt2 = new Appointment();
        appt2.setId(2L);
        when(appointmentService.getAllAppointments())
                .thenReturn(Arrays.asList(appointment, appt2));

        ResponseEntity<List<Appointment>> response = controller.getAll();

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(2, response.getBody().size());
        verify(appointmentService, times(1)).getAllAppointments();
    }

    @Test
    void getAll_ShouldReturnSingleItemList() {
        when(appointmentService.getAllAppointments())
                .thenReturn(Collections.singletonList(appointment));

        ResponseEntity<List<Appointment>> response = controller.getAll();

        assertEquals(1, response.getBody().size());
    }

    // ─────────────────────────────────────────────
    // GET /appointments/patient/{patientId}
    // ─────────────────────────────────────────────

    @Test
    void getByPatient_ShouldReturn200WithAppointmentList() {
        when(appointmentService.getAppointmentsByPatient(10L))
                .thenReturn(Collections.singletonList(appointment));

        ResponseEntity<List<Appointment>> response = controller.getByPatient(10L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(1, response.getBody().size());
        assertEquals(10L, response.getBody().get(0).getPatientId());
        verify(appointmentService, times(1)).getAppointmentsByPatient(10L);
    }

    @Test
    void getByPatient_ShouldPassCorrectPatientIdToService() {
        when(appointmentService.getAppointmentsByPatient(5L))
                .thenReturn(Collections.emptyList());

        controller.getByPatient(5L);

        verify(appointmentService).getAppointmentsByPatient(5L);
    }

    // ─────────────────────────────────────────────
    // GET /appointments/doctor/{doctorId}
    // ─────────────────────────────────────────────

    @Test
    void getByDoctor_ShouldReturn200WithAppointmentList() {
        when(appointmentService.getAppointmentsByDoctor(20L))
                .thenReturn(Collections.singletonList(appointment));

        ResponseEntity<List<Appointment>> response = controller.getByDoctor(20L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(1, response.getBody().size());
        assertEquals(20L, response.getBody().get(0).getDoctorId());
        verify(appointmentService, times(1)).getAppointmentsByDoctor(20L);
    }

    @Test
    void getByDoctor_ShouldPassCorrectDoctorIdToService() {
        when(appointmentService.getAppointmentsByDoctor(7L))
                .thenReturn(Collections.emptyList());

        controller.getByDoctor(7L);

        verify(appointmentService).getAppointmentsByDoctor(7L);
    }

    

    @Test
    void cancel_ShouldReturn200WithCancelledAppointment() {
        appointment.setStatus(AppointmentStatus.CANCELLED);
        CancelRequest cancelRequest = new CancelRequest();
        cancelRequest.setReason("Patient unavailable");

        when(appointmentService.cancelAppointment(1L, "Patient unavailable"))
                .thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.cancel(1L, cancelRequest);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(AppointmentStatus.CANCELLED, response.getBody().getStatus());
        verify(appointmentService, times(1)).cancelAppointment(1L, "Patient unavailable");
    }

    @Test
    void cancel_ShouldExtractReasonFromCancelRequest() {
        CancelRequest cancelRequest = new CancelRequest();
        cancelRequest.setReason("Emergency");

        when(appointmentService.cancelAppointment(2L, "Emergency"))
                .thenReturn(appointment);

        controller.cancel(2L, cancelRequest);

        verify(appointmentService).cancelAppointment(2L, "Emergency");
        verify(appointmentService, never()).cancelAppointment(2L, "Patient unavailable");
    }

   
   

    @Test
    void complete_ShouldReturn200WithCompletedAppointment() {
        appointment.setStatus(AppointmentStatus.COMPLETED);
        when(appointmentService.completeAppointment(1L)).thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.complete(1L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(AppointmentStatus.COMPLETED, response.getBody().getStatus());
        verify(appointmentService, times(1)).completeAppointment(1L);
    }

    @Test
    void complete_ShouldPassCorrectIdToService() {
        when(appointmentService.completeAppointment(3L)).thenReturn(appointment);

        controller.complete(3L);

        verify(appointmentService).completeAppointment(3L);
        verify(appointmentService, never()).completeAppointment(1L);
    }

    

    @Test
    void markPaymentSuccess_ShouldReturn200WithConfirmedAppointment() {
        appointment.setStatus(AppointmentStatus.CONFIRMED);
        when(appointmentService.markPaymentSuccess(1L)).thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.markPaymentSuccess(1L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(AppointmentStatus.CONFIRMED, response.getBody().getStatus());
        verify(appointmentService, times(1)).markPaymentSuccess(1L);
    }

    @Test
    void markPaymentSuccess_ShouldDelegateToServiceCorrectly() {
        when(appointmentService.markPaymentSuccess(5L)).thenReturn(appointment);

        controller.markPaymentSuccess(5L);

        verify(appointmentService).markPaymentSuccess(5L);
        verifyNoMoreInteractions(appointmentService);
    }

   

    @Test
    void refundCompleted_ShouldReturn200WithRefundedStatus() {
        appointment.setRefundStatus("REFUNDED");
        when(appointmentService.markRefundCompleted(1L)).thenReturn(appointment);

        ResponseEntity<Appointment> response = controller.refundCompleted(1L);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("REFUNDED", response.getBody().getRefundStatus());
        verify(appointmentService, times(1)).markRefundCompleted(1L);
    }

    @Test
    void refundCompleted_ShouldPassCorrectIdToService() {
        when(appointmentService.markRefundCompleted(8L)).thenReturn(appointment);

        controller.refundCompleted(8L);

        verify(appointmentService).markRefundCompleted(8L);
    }
}